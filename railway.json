{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "python3 -m pip install --upgrade pip && cd server && pip install -r requirements.txt && python manage.py collectstatic --noinput",
    "watchPatterns": ["server/**"]
  },
  "deploy": {
    "startCommand": "cd server && gunicorn taskmanager.wsgi:application --bind 0.0.0.0:$PORT",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
